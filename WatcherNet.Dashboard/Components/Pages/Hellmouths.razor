@page "/hellmouths"
@rendermode InteractiveServer
@inject IHttpClientFactory HttpClientFactory

<PageTitle>WatcherNet — Hellmouths</PageTitle>

<h1 class="page-title">Hellmouth Threat Monitor</h1>
<p class="page-subtitle">Location-based threat activity and risk assessment</p>

<div class="search-bar">
    <div class="form-group" style="flex: 1; margin-bottom: 0;">
        <input class="form-control" @bind="location" @bind:event="oninput"
               @onkeydown="OnKeyDown" placeholder="Enter location (e.g. Sunnydale, Cleveland, London)" />
    </div>
    <button class="btn btn-primary" @onclick="LookUp" disabled="@(string.IsNullOrWhiteSpace(location))">
        Assess
    </button>
</div>

<div class="quick-lookup">
    @foreach (var loc in new[] { "Sunnydale", "Cleveland", "Boston", "London", "Rome" })
    {
        <button class="btn btn-ghost" @onclick="() => QuickLook(loc)">@loc</button>
    }
</div>

@if (loading)
{
    <p class="loading">Scanning for supernatural activity...</p>
}
else if (error)
{
    <div class="alert alert-error">No threat data for "@location". Location may be unmonitored.</div>
}
else if (stats is not null)
{
    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-label">Total Encounters</div>
            <div class="stat-value gold">@stats.TotalEncounters</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Active Threats</div>
            <div class="stat-value danger">@stats.ActiveThreats</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Threat Level</div>
            <div class="stat-value">
                <span class="threat-badge threat-@stats.ThreatLevel.ToLower()">@stats.ThreatLevel</span>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Slayers Deployed</div>
            <div class="stat-value">@stats.BySlayer.Count</div>
        </div>
    </div>

    <div class="two-col">
        <div class="card">
            <div class="card-title">Threats by Type</div>
            @if (stats.ByCreatureType.Any())
            {
                <table class="breakdown-table">
                    <thead><tr><th>Creature</th><th>Sightings</th></tr></thead>
                    <tbody>
                        @foreach (var kv in stats.ByCreatureType.OrderByDescending(x => x.Value))
                        {
                            <tr><td>@kv.Key</td><td>@kv.Value</td></tr>
                        }
                    </tbody>
                </table>
            }
            else { <p class="loading">No threat data.</p> }
        </div>
        <div class="card">
            <div class="card-title">Slayers Active Here</div>
            @if (stats.BySlayer.Any())
            {
                <table class="breakdown-table">
                    <thead><tr><th>Slayer</th><th>Engagements</th></tr></thead>
                    <tbody>
                        @foreach (var kv in stats.BySlayer.OrderByDescending(x => x.Value))
                        {
                            <tr><td>@kv.Key</td><td>@kv.Value</td></tr>
                        }
                    </tbody>
                </table>
            }
            else { <p class="loading">No slayer data.</p> }
        </div>
    </div>
}

@code {
    private string location = "";
    private HellmouthStats? stats;
    private bool loading = false;
    private bool error = false;

    private async Task LookUp()
    {
        if (string.IsNullOrWhiteSpace(location)) return;
        loading = true; error = false; stats = null;
        try
        {
            var client = HttpClientFactory.CreateClient("api");
            stats = await client.GetFromJsonAsync<HellmouthStats>($"/hellmouths/{Uri.EscapeDataString(location.Trim())}");
            error = stats is null || stats.TotalEncounters == 0;
        }
        catch { error = true; }
        finally { loading = false; }
    }

    private async Task QuickLook(string loc)
    {
        location = loc;
        await LookUp();
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await LookUp();
    }
}
