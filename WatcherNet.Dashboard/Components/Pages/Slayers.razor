@page "/slayers"
@rendermode InteractiveServer
@inject IHttpClientFactory HttpClientFactory

<PageTitle>WatcherNet — Slayers</PageTitle>

<h1 class="page-title">Slayer Combat Records</h1>
<p class="page-subtitle">Individual field statistics by slayer</p>

<div class="search-bar">
    <div class="form-group" style="flex: 1; margin-bottom: 0;">
        <input class="form-control" @bind="slayerName" @bind:event="oninput"
               @onkeydown="OnKeyDown" placeholder="Enter slayer name (e.g. Buffy, Faith, Kendra)" />
    </div>
    <button class="btn btn-primary" @onclick="LookUp" disabled="@(string.IsNullOrWhiteSpace(slayerName))">
        Look Up
    </button>
</div>

<div class="quick-lookup">
    @foreach (var name in new[] { "Buffy", "Faith", "Kendra", "Rona", "Amanda", "Spike" })
    {
        <button class="btn btn-ghost" @onclick="() => QuickLook(name)">@name</button>
    }
</div>

@if (loading)
{
    <p class="loading">Retrieving field records...</p>
}
else if (error)
{
    <div class="alert alert-error">No records found for "@slayerName". Have they filed their reports?</div>
}
else if (stats is not null)
{
    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-label">Total Encounters</div>
            <div class="stat-value gold">@stats.TotalEncounters</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Neutralized</div>
            <div class="stat-value success">@stats.Neutralized</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Escaped</div>
            <div class="stat-value danger">@stats.Escaped</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Effectiveness</div>
            <div class="stat-value">
                @(stats.TotalEncounters > 0
                    ? $"{(stats.Neutralized * 100 / stats.TotalEncounters)}%"
                    : "—")
            </div>
        </div>
    </div>

    <div class="two-col">
        <div class="card">
            <div class="card-title">By Creature Type</div>
            @if (stats.ByCreatureType.Any())
            {
                <table class="breakdown-table">
                    <thead><tr><th>Creature</th><th>Encounters</th></tr></thead>
                    <tbody>
                        @foreach (var kv in stats.ByCreatureType.OrderByDescending(x => x.Value))
                        {
                            <tr><td>@kv.Key</td><td>@kv.Value</td></tr>
                        }
                    </tbody>
                </table>
            }
            else { <p class="loading">No data yet.</p> }
        </div>
        <div class="card">
            <div class="card-title">By Location</div>
            @if (stats.ByLocation.Any())
            {
                <table class="breakdown-table">
                    <thead><tr><th>Location</th><th>Encounters</th></tr></thead>
                    <tbody>
                        @foreach (var kv in stats.ByLocation.OrderByDescending(x => x.Value))
                        {
                            <tr><td>@kv.Key</td><td>@kv.Value</td></tr>
                        }
                    </tbody>
                </table>
            }
            else { <p class="loading">No data yet.</p> }
        </div>
    </div>
}

@code {
    private string slayerName = "";
    private SlayerStats? stats;
    private bool loading = false;
    private bool error = false;

    private async Task LookUp()
    {
        if (string.IsNullOrWhiteSpace(slayerName)) return;
        loading = true; error = false; stats = null;
        try
        {
            var client = HttpClientFactory.CreateClient("api");
            stats = await client.GetFromJsonAsync<SlayerStats>($"/slayers/{Uri.EscapeDataString(slayerName.Trim())}");
            error = stats is null || stats.TotalEncounters == 0;
        }
        catch { error = true; }
        finally { loading = false; }
    }

    private async Task QuickLook(string name)
    {
        slayerName = name;
        await LookUp();
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await LookUp();
    }
}
